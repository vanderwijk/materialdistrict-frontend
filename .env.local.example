# MaterialDistrict — Environment variabelen
# Kopieer dit bestand naar `.env.local` en vul de echte waarden in.
# `.env.local` staat in .gitignore en mag NOOIT worden gecommit.

# -- WordPress REST API --
WP_API_URL=https://materialdistrict.com/wp-json
WP_APP_USER=
WP_APP_PASSWORD=

# -- WooCommerce REST API --
WC_API_URL=https://materialdistrict.com/wp-json/wc/v3
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- FacetWP --
# FacetWP gebruikt dezelfde basis als de WP REST API, maar via een eigen endpoint.
# Wordt opgebouwd uit WP_API_URL + /facetwp/v1
# Niet apart instelbaar tenzij FacetWP op een andere host draait.

# -- Public site URL (voor canonical, sitemap, OG-tags) --
NEXT_PUBLIC_SITE_URL=https://materialdistrict.com

# -- Revalidation --
# Geheim voor on-demand revalidation (webhook vanuit WordPress)
REVALIDATE_SECRET=
