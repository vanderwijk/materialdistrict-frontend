# MaterialDistrict — Environment variabelen
# Kopieer dit bestand naar `.env.local` en vul de echte waarden in.
# `.env.local` staat in .gitignore en mag NOOIT worden gecommit.

# -- WordPress REST API --
WP_API_URL=https://cms.materialdistrict.com/wp-json
WP_APP_USER=
WP_APP_PASSWORD=

# -- WooCommerce REST API --
WC_API_URL=https://cms.materialdistrict.com/wp-json/wc/v3
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Public site URL (voor canonical, sitemap, OG-tags) --
NEXT_PUBLIC_SITE_URL=https://materialdistrict.com

# -- WooCommerce Store API (cart) --
# Cart loopt via `/api/store-cart` (server-side proxy met WP_API_URL + JWT).
# NEXT_PUBLIC_WP_URL is niet meer nodig voor de winkelmand.

# -- Revalidation --
# Geheim voor on-demand revalidation (webhook vanuit WordPress)
REVALIDATE_SECRET=

# -- Authenticatie --
# De JWT-secret leeft AAN WP-KANT — niet in deze .env. Definieer in
# wp-config.php (zowel LocalWP als productie):
#
#   define( 'MD_JWT_SECRET', 'een-lange-willekeurige-string' );
#
# Genereer bv. via:  openssl rand -base64 64
# De Next.js-frontend hoeft de secret zelf niet te kennen — alle JWT-validatie
# gebeurt via het WP-endpoint.

# -- Social login (Google + LinkedIn) --
# Redirect URI (in beide provider-consoles):
#   {NEXT_PUBLIC_SITE_URL}/api/auth/oauth/callback
# Voor preview/staging: ook de Vercel-URL toevoegen.
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
#   (Web application). Scopes: openid, email, profile.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# LinkedIn Developers → Create app → Auth → OpenID Connect
#   Products: "Sign In with LinkedIn using OpenID Connect"
#   Scopes: openid, profile, email
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
#
# Optioneel: eigen secret voor OAuth state-cookie signing (anders REVALIDATE_SECRET).
OAUTH_STATE_SECRET=
#
# Op WordPress (wp-config.php), optioneel audience-check voor Google:
#   define( 'MD_OAUTH_GOOGLE_CLIENT_ID', '....apps.googleusercontent.com' );
